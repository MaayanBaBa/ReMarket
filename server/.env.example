## Mongo (use Atlas connection string in production, e.g. on Render)
# Local:   mongodb://localhost:27017/ReMarket
# Atlas:   mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/ReMarket
MONGO_URI=mongodb://localhost:27017/ReMarket

## Server
# Render injects PORT automatically; only set this for local dev if you want
PORT=5000

## Auth
JWT_SECRET=change_me_to_a_long_random_string

## CORS / Socket.IO origin(s) — comma-separated list of allowed front-end URLs
# Local dev: http://localhost:3000
# Production: e.g. https://your-app.netlify.app,https://your-app.onrender.com
CLIENT_URL=http://localhost:3000

## Main admin (only one)
ADMIN_EMAIL=admin@remarket.com
ADMIN_PASSWORD=Admin1234
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Main

